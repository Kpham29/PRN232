@model List<BorrowSlipVm>
@{ ViewData["Title"] = "Tạo phiếu phạt"; }

<h4 class="mb-3"><i class="bi bi-plus-circle me-1"></i> Tạo phiếu phạt mới</h4>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Chọn phiếu mượn <span class="text-danger">*</span></label>
                        <select name="borrowSlipId" class="form-select text-dark" required style="color: black !important;">
                            <option value="">-- Chọn phiếu mượn --</option>
                            @foreach (var b in Model)
                            {
                                <option value="@b.Id">[@b.SlipCode] - Độc giả: @b.ReaderName - Ngày mượn: @b.BorrowedAt.ToString("dd/MM/yyyy") (@b.Status)</option>
                            }
                        </select>
                        <div class="form-text">Mỗi phiếu mượn chỉ có thể có tối đa một phiếu phạt.</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark">Số tiền phạt (VNĐ) <span class="text-danger">*</span></label>
                            <input type="number" name="fineAmount" class="form-control text-dark" required step="1000" style="color: black !important;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark">Lý do <span class="text-danger">*</span></label>
                            <select name="reason" class="form-select text-dark" required style="color: black !important;">
                                <option value="Overdue">Quá hạn (Overdue)</option>
                                <option value="DamagedBook">Làm hỏng sách (DamagedBook)</option>
                                <option value="LostBook">Làm mất sách (LostBook)</option>
                                <option value="Other">Lý do khác (Other)</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Ghi chú</label>
                        <textarea name="note" class="form-control text-dark" rows="3" style="color: black !important;"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning px-4">Tạo phiếu phạt</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="alert alert-info">
            <h6 class="alert-heading fw-bold"><i class="bi bi-info-circle me-1"></i> Hướng dẫn</h6>
            <p class="small mb-0">
                Librarian có thể tạo phiếu phạt thủ công khi độc giả làm hỏng hoặc mất sách. 
                Hệ thống cũng tự động tạo phiếu phạt "Overdue" khi phát hiện sách quá hạn.
            </p>
        </div>
    </div>
</div>
