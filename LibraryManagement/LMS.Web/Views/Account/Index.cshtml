@model List<AccountVm>
@{ ViewData["Title"] = "Quản lý tài khoản"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-shield-lock me-1"></i> Quản lý tài khoản</h4>
    <a asp-action="CreateLibrarian" class="btn btn-primary btn-sm">
        <i class="bi bi-person-plus me-1"></i> Thêm thủ thư
    </a>
</div>

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm @(ViewBag.Role==null?"btn-secondary":"btn-outline-secondary")">Tất cả</a>
    <a asp-action="Index" asp-route-role="Admin" class="btn btn-sm @(ViewBag.Role=="Admin"?"btn-danger":"btn-outline-danger")">Admin</a>
    <a asp-action="Index" asp-route-role="Librarian" class="btn btn-sm @(ViewBag.Role=="Librarian"?"btn-info":"btn-outline-info")">Thủ thư</a>
    <a asp-action="Index" asp-route-role="Reader" class="btn btn-sm @(ViewBag.Role=="Reader"?"btn-success":"btn-outline-success")">Độc giả</a>
</div>

<table class="table table-bordered table-hover table-sm">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Họ và tên</th>
            <th>Email</th>
            <th>Quyền</th>
            <th>Ngày tham gia</th>
            <th>Trạng thái</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach(var a in Model) {
        <tr>
            <td>@a.Id</td>
            <td>@a.FullName</td>
            <td>@a.Email</td>
            <td>
                @{
                    var badgeClass = a.Role switch {
                        "Admin" => "bg-danger",
                        "Librarian" => "bg-info text-dark",
                        "Reader" => "bg-success",
                        _ => "bg-secondary"
                    };
                }
                <span class="badge @badgeClass">@a.Role</span>
            </td>
            <td>@a.CreatedAt.ToString("dd/MM/yyyy")</td>
            <td>
                @if(a.IsActive) {
                    <span class="badge bg-success">Hoạt động</span>
                } else {
                    <span class="badge bg-secondary">Bị khóa</span>
                }
            </td>
            <td class="text-center">
                @if(a.Role != "Admin") {
                    <form asp-action="Toggle" asp-route-id="@a.Id" method="post" style="display:inline;">
                        @if(a.IsActive) {
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Khóa tài khoản này?');" title="Khóa">Lock</button>
                        } else {
                            <button type="submit" class="btn btn-sm btn-outline-success" onclick="return confirm('Mở khóa tài khoản này?');" title="Mở khóa">Unlock</button>
                        }
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
