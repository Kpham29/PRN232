@model CategoryVm
@{ ViewData["Title"] = "Thêm thể loại mới"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">Thêm thể loại mới</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label small fw-bold">Tên thể loại</label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên thể loại..." />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">Lưu</button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
