@model DashboardVm
@{ ViewData["Title"] = "Dashboard Quản lý"; }

<h3 class="mb-4 fw-bold text-dark"><i class="bi bi-speedometer2 me-2"></i> Dashboard Quản lý</h3>

<!-- Stats Row -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-uppercase small fw-bold opacity-75">Tổng số sách</h6>
                        <h2 class="mb-0">@Model.Stats.TotalBooks</h2>
                    </div>
                    <i class="bi bi-book fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-uppercase small fw-bold opacity-75">Độc giả</h6>
                        <h2 class="mb-0">@Model.Stats.TotalReaders</h2>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-uppercase small fw-bold opacity-75">Đang mượn</h6>
                        <h2 class="mb-0">@Model.Stats.ActiveBorrows</h2>
                    </div>
                    <i class="bi bi-clipboard-check fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-uppercase small fw-bold opacity-75">Tiền phạt chưa thu</h6>
                        <h2 class="mb-0">@Model.Stats.TotalFineAmount.ToString("N0")đ</h2>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Overdue Table -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 text-dark fw-bold"><i class="bi bi-calendar-x me-2 text-danger"></i> Sách quá hạn chưa trả (@Model.Stats.OverdueBorrows)</h6>
                <a asp-controller="BorrowSlip" asp-action="Index" asp-route-status="Borrowing" class="btn btn-sm btn-link p-0 text-decoration-none small">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 small">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-3 border-0">Phiếu</th>
                                <th class="border-0">Độc giả</th>
                                <th class="border-0">Ngày trả dự kiến</th>
                                <th class="border-0">Sách</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if(!Model.OverdueBooks.Any()) {
                                <tr><td colspan="4" class="text-center py-4 text-muted">Không có sách quá hạn.</td></tr>
                            }
                            @foreach(var item in Model.OverdueBooks) {
                                <tr>
                                    <td class="ps-3 border-0 fw-bold"><code>@item.SlipCode</code></td>
                                    <td class="border-0">@item.ReaderName</td>
                                    <td class="border-0 text-danger fw-bold">@item.DueDate.ToString("dd/MM/yyyy")</td>
                                    <td class="border-0">
                                        <ul class="list-unstyled mb-0">
                                            @foreach(var d in item.Details) {
                                                <li>- @d.BookTitle</li>
                                            }
                                        </ul>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Books -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="mb-0 text-dark fw-bold"><i class="bi bi-graph-up-arrow me-2 text-success"></i> Top sách mượn nhiều nhất</h6>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush small">
                    @if(!Model.TopBooks.Any()) {
                        <div class="p-4 text-center text-muted">Chưa có dữ liệu thống kê.</div>
                    }
                    @foreach(var b in Model.TopBooks) {
                        <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-3 py-2">
                            <div class="d-flex align-items-center me-2">
                                <div class="badge bg-light text-muted me-3">#@(Model.TopBooks.IndexOf(b)+1)</div>
                                <div>
                                    <div class="fw-bold">@b.Title</div>
                                    <div class="text-muted opacity-75 small">@b.Author</div>
                                </div>
                            </div>
                            <span class="badge bg-success-subtle text-success rounded-pill fw-bold">@b.BorrowCount lượt</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
