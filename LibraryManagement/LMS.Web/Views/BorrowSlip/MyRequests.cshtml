@using LMS.Web.Models
@model List<BorrowRequestVm>
@{ ViewData["Title"] = "Yêu cầu của tôi"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h3 fw-bold mb-0 text-dark">
        <i class="bi bi-clock-history text-primary me-2"></i>Yêu cầu mượn sách
    </h2>
    <a asp-controller="Book" asp-action="Index" class="btn btn-primary shadow-sm px-4">
        <i class="bi bi-search me-2"></i>Tìm sách mới
    </a>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Ngày yêu cầu</th>
                    <th>Sách</th>
                    <th>Ghi chú</th>
                    <th>Trạng thái</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any()) {
                    <tr><td colspan="5" class="text-center py-5 text-muted fw-medium border-0">Bạn chưa có yêu cầu mượn sách nào.</td></tr>
                }
                @foreach (var r in Model) {
                    <tr>
                        <td class="ps-4 text-muted small fw-medium">@r.RequestedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div class="fw-bold text-dark">@r.BookTitle</div>
                        </td>
                        <td>
                            <div class="text-muted small text-truncate fw-medium" style="max-width: 220px;" title="@r.Note">
                                @(r.Note ?? "—")
                            </div>
                        </td>
                        <td>
                            @{
                                var badgeClass = r.Status switch {
                                    "Pending" => "bg-warning text-dark",
                                    "Approved" => "bg-success text-white",
                                    "Rejected" => "bg-danger text-white",
                                    "Cancelled" => "bg-secondary text-white",
                                    _ => "bg-secondary text-white"
                                };
                            }
                            <span class="badge rounded-pill @badgeClass px-3">
                                @if (r.Status == "Pending") { <i class="bi bi-hourglass-split me-1"></i> }
                                @if (r.Status == "Approved") { <i class="bi bi-check-circle-fill me-1"></i> }
                                @if (r.Status == "Rejected") { <i class="bi bi-x-circle-fill me-1"></i> }
                                @if (r.Status == "Cancelled") { <i class="bi bi-slash-circle me-1"></i> }
                                @r.Status
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            @if (r.Status == "Pending") {
                                <form asp-action="CancelRequest" asp-route-id="@r.Id" method="post">
                                    <button type="submit" class="btn btn-sm btn-danger shadow-sm px-3" 
                                            onclick="return confirm('Bạn chắc chắn muốn hủy yêu cầu này?')">
                                        <i class="bi bi-trash-fill me-1"></i> Hủy yêu cầu
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
