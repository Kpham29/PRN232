@model List<BorrowSlipVm>
@{ ViewData["Title"] = "Phiếu mượn của tôi"; }
<h4 class="mb-3"><i class="bi bi-clipboard-check me-1"></i> Phiếu mượn của tôi</h4>

<table class="table table-bordered table-hover table-sm">
    <thead class="table-dark">
        <tr>
            <th>Mã phiếu</th>
            <th>Ngày mượn</th><th>Hạn trả</th><th>Ngày trả</th>
            <th>Trạng thái</th><th>Sách mượn</th>
        </tr>
    </thead>
    <tbody>
    @if(!Model.Any()) {
        <tr><td colspan="6" class="text-center">Chưa mượn cuốn sách nào.</td></tr>
    }
    @foreach (var s in Model) {
        <tr class="@(s.IsOverdue ? "table-danger" : s.Status=="Returned" ? "table-success" : "")">
            <td><code class="small">@s.SlipCode</code><br/><small class="text-muted">@s.LibrarianName ghi nhận</small></td>
            <td>@s.BorrowedAt.ToString("dd/MM/yyyy")</td>
            <td class="@(s.IsOverdue ? "fw-bold" : "")">@s.DueDate.ToString("dd/MM/yyyy")</td>
            <td>@(s.ReturnedAt?.ToString("dd/MM/yyyy") ?? "—")</td>
            <td>
                <span class="badge bg-@(s.Status=="Borrowing"?"primary":s.Status=="Returned"?"success":"danger")">
                    @s.Status
                </span>
                @if (s.HasFine) {
                    <span class="badge bg-warning text-dark">
                        Phạt @s.FineAmount?.ToString("N0")đ
                    </span>
                }
            </td>
            <td class="small text-muted">
                <ul class="mb-0 ps-3">
                    @foreach(var d in s.Details) {
                        <li>@d.BookTitle (x@d.Quantity)</li>
                    }
                </ul>
            </td>
        </tr>
    }
    </tbody>
</table>
