@model List<BorrowSlipVm>
@{ ViewData["Title"] = "Quản lý mượn trả"; }

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
        <h2 class="h3 fw-bold mb-1 text-dark">
            <i class="bi bi-clipboard-check text-primary me-2"></i>Quản lý mượn trả
        </h2>
        <p class="text-muted small mb-0 fw-medium">Theo dõi và quản lý các giao dịch mượn trả sách</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" asp-route-status="Borrowing"
           class="btn btn-sm btn-primary shadow-sm @(ViewBag.Status=="Borrowing"?"":"bg-opacity-10 text-primary border-primary") fw-bold px-3">
            Đang mượn
        </a>
        <a asp-action="Index" asp-route-status="Overdue"
           class="btn btn-sm btn-danger shadow-sm @(ViewBag.Status=="Overdue"?"":"bg-opacity-10 text-danger border-danger") fw-bold px-3">
            Quá hạn
        </a>
        <a asp-action="Index" asp-route-status="Returned"
           class="btn btn-sm btn-success shadow-sm @(ViewBag.Status=="Returned"?"":"bg-opacity-10 text-success border-success") fw-bold px-3">
            Đã trả
        </a>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary border-opacity-50 fw-bold px-3">Tất cả</a>
        
        @if (Context.Session.GetString("role") == "Librarian") {
            <a asp-action="Create" class="btn btn-sm btn-primary shadow-sm px-4">
                <i class="bi bi-plus-lg me-1"></i> Tạo mới
            </a>
        }
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Mã phiếu</th>
                    <th>Độc giả</th>
                    <th>Ngày mượn</th>
                    <th>Hạn trả</th>
                    <th>Ngày trả</th>
                    <th>Trạng thái</th>
                    <th>Sách</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any()) {
                <tr><td colspan="8" class="text-center py-5 text-muted fw-medium border-0">Không tìm thấy phiếu mượn nào.</td></tr>
            }
            @foreach (var s in Model) {
                <tr>
                    <td class="ps-4">
                        <span class="font-monospace small text-primary fw-bold">@s.SlipCode</span>
                    </td>
                    <td>
                        <div class="fw-bold text-dark">@s.ReaderName</div>
                        <div class="text-muted small fw-medium">Card: @s.CardNumber</div>
                    </td>
                    <td class="small fw-medium">@s.BorrowedAt.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div class="small fw-bold @(s.IsOverdue ? "text-danger" : "text-dark")">
                            @s.DueDate.ToString("dd/MM/yyyy")
                        </div>
                    </td>
                    <td class="small text-muted">@(s.ReturnedAt?.ToString("dd/MM/yyyy") ?? "—")</td>
                    <td>
                        @{
                            var badgeClass = s.Status switch {
                                "Borrowing" => "bg-primary text-white",
                                "Returned" => "bg-success text-white",
                                "Overdue" => "bg-danger text-white",
                                _ => "bg-secondary text-white"
                            };
                        }
                        <span class="badge rounded-pill @badgeClass px-3">
                            @s.Status
                        </span>
                        @if (s.HasFine) {
                            <div class="mt-1 small text-warning fw-bold d-flex align-items-center">
                                <i class="bi bi-exclamation-circle-fill me-1"></i>@s.FineAmount?.ToString("N0")đ
                            </div>
                        }
                    </td>
                    <td class="small text-muted">
                        <div class="d-flex flex-wrap gap-1" style="max-width: 200px;">
                            @foreach(var d in s.Details) {
                                <span class="badge bg-light text-dark border border-secondary border-opacity-10">@d.BookTitle</span>
                            }
                        </div>
                    </td>
                    <td class="text-end pe-4">
                        <div class="d-flex gap-2 justify-content-end align-items-center">
                            @if (s.Status is "Borrowing" or "Overdue") {
                                <form asp-action="Return" asp-route-id="@s.Id" method="post">
                                    <button class="btn btn-sm btn-primary shadow-sm px-3" onclick="return confirm('Xác nhận trả sách?')">
                                        <i class="bi bi-box-arrow-in-left me-1"></i> Trả sách
                                    </button>
                                </form>
                            }
                            @if (s.Status == "Borrowing") {
                                <form asp-action="Renew" asp-route-id="@s.Id" method="post">
                                    <button type="submit" class="btn btn-sm btn-outline-primary px-3 fw-bold"
                                            onclick="return confirm('Gia hạn thêm 7 ngày cho phiếu này?')">
                                        <i class="bi bi-calendar-plus me-1"></i> Gia hạn
                                    </button>
                                </form>
                            }
                            <a asp-action="Detail" asp-route-id="@s.Id" class="btn btn-sm btn-light text-muted px-2" title="Chi tiết">
                                <i class="bi bi-three-dots"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
