@model ReaderVm
@{ ViewData["Title"] = "Hồ sơ của tôi"; }

<style>
    .profile-card {
        border-radius: 20px;
        overflow: hidden;
        border: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .profile-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
    .profile-header {
        background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
        padding: 2.5rem 2rem;
        position: relative;
    }
    .profile-header::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 40px;
        background: white;
        clip-path: polygon(0 100%, 100% 100%, 100% 0);
    }
    .profile-id-badge {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(5px);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        font-size: 0.85rem;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }
    .info-label {
        color: #64748b;
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.25rem;
    }
    .info-value {
        color: #0f172a; /* Dark Slate / Black */
        font-weight: 500;
        font-size: 1.1rem;
        word-break: break-word;
    }
    .info-value.highlight {
        font-size: 1.4rem;
        font-weight: 700;
        color: #1e3a8a;
    }
    .section-title {
        color: #1e3a8a;
        font-weight: 700;
        border-bottom: 2px solid #e2e8f0;
        padding-bottom: 0.5rem;
    }
    .status-badge {
        padding: 0.6rem 1.2rem;
        border-radius: 12px;
        font-weight: 600;
    }
</style>

<div class="row justify-content-center py-5">
    <div class="col-lg-9 col-xl-8">
        <div class="card profile-card shadow-lg bg-white">
            <div class="profile-header text-white">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <h2 class="fw-bold mb-1">Hồ sơ Độc giả</h2>
                        <p class="opacity-75 mb-0">Quản lý thông tin cá nhân và thẻ thư viện của bạn</p>
                    </div>
                    <div class="profile-id-badge">
                        <i class="bi bi-card-heading me-1"></i> @Model.CardNumber
                    </div>
                </div>
            </div>
            
            <div class="card-body p-4 p-md-5 pt-2">
                <div class="row g-5">
                    <div class="col-md-6 border-end-md">
                        <h5 class="section-title mb-4"><i class="bi bi-person-circle me-2"></i>Thông tin cá nhân</h5>
                        
                        <div class="row g-4">
                            <div class="col-12">
                                <div class="info-label">Họ và tên</div>
                                <div class="info-value highlight">@Model.FullName</div>
                            </div>
                            
                            <div class="col-6">
                                <div class="info-label">Giới tính</div>
                                <div class="info-value">@(Model.Gender == "Male" ? "Nam" : "Nữ")</div>
                            </div>
                            
                            <div class="col-6">
                                <div class="info-label">Số điện thoại</div>
                                <div class="info-value">@(Model.Phone ?? "Chưa cập nhật")</div>
                            </div>
                            
                            <div class="col-12">
                                <div class="info-label">Địa chỉ liên lạc</div>
                                <div class="info-value">@(Model.Address ?? "Chưa cập nhật")</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <h5 class="section-title mb-4"><i class="bi bi-credit-card-2-front me-2"></i>Thẻ thư viện</h5>
                        
                        <div class="row g-4">
                            <div class="col-6">
                                <div class="info-label">Ngày cấp thẻ</div>
                                <div class="info-value">@Model.CardIssuedDate.ToString("dd/MM/yyyy")</div>
                            </div>
                            
                            <div class="col-6">
                                <div class="info-label">Ngày hết hạn</div>
                                <div class="info-value text-@(Model.IsCardValid ? "dark" : "danger")">
                                    @Model.CardExpiredDate.ToString("dd/MM/yyyy")
                                </div>
                            </div>
                            
                            <div class="col-12 mt-4">
                                <div class="info-label mb-2">Trạng thái hiện tại</div>
                                @if(Model.IsCardValid) {
                                    <div class="status-badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 pb-3">
                                        <i class="bi bi-check-circle-fill me-2"></i>Thẻ đang hoạt động bình thường
                                    </div>
                                } else if (!Model.IsCardActive) {
                                    <div class="status-badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 pb-3">
                                        <i class="bi bi-lock-fill me-2"></i>Thẻ đã bị khóa bởi quản trị viên
                                    </div>
                                } else {
                                    <div class="status-badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 pb-3">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Thẻ đã hết hạn sử dụng
                                    </div>
                                }
                            </div>
                            
                            <div class="col-12 mt-4">
                                <div class="alert alert-indigo border-0 rounded-4 shadow-sm bg-light mb-0 d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3 text-primary">
                                        <i class="bi bi-lightning-charge-fill"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-bold small">Cần thêm thời gian?</div>
                                        <div class="text-muted extra-small">Gia hạn ngay để tiếp tục mượn sách.</div>
                                    </div>
                                    <a asp-action="RenewCard" class="btn btn-primary btn-sm rounded-3 shadow-sm px-3 ms-2">
                                        Gia hạn thẻ
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card-footer bg-light border-0 p-4 d-flex justify-content-between align-items-center">
                <span class="text-muted small">ID Hệ thống: #BS-@Model.CardNumber.GetHashCode().ToString("X").Substring(0, 6)</span>
                <a asp-controller="Auth" asp-action="ChangePassword" class="btn btn-outline-dark btn-sm rounded-pill px-4">
                    <i class="bi bi-shield-lock me-1"></i> Bảo mật tài khoản
                </a>
            </div>
        </div>
    </div>
</div>
