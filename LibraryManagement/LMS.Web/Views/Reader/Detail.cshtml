@model ReaderVm
@{ ViewData["Title"] = "Chi tiết độc giả"; }

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-person-badge me-1"></i> Thông tin thẻ độc giả</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <p><strong>Mã thẻ:</strong> <span class="badge bg-secondary font-monospace">@Model.CardNumber</span></p>
                <p><strong>Họ tên:</strong> @Model.FullName</p>
                <p><strong>Giới tính:</strong> @(Model.Gender == "Male" ? "Nam" : "Nữ")</p>
                <p><strong>Số điện thoại:</strong> @(Model.Phone ?? "—")</p>
                <p><strong>Địa chỉ:</strong> @(Model.Address ?? "—")</p>
            </div>
            <div class="col-md-6 text-end">
                <p><strong>Ngày cấp:</strong> @Model.CardIssuedDate.ToString("dd/MM/yyyy")</p>
                <p><strong>Ngày hết hạn:</strong> <span class="text-@(Model.IsCardValid ? "success" : "danger") fw-bold">@Model.CardExpiredDate.ToString("dd/MM/yyyy")</span></p>
                <p><strong>Trình trạng:</strong> 
                    @if(Model.IsCardValid) {
                        <span class="badge bg-success">Đang hoạt động</span>
                    } else if (!Model.IsCardActive) {
                        <span class="badge bg-secondary">Bị khóa</span>
                    } else {
                        <span class="badge bg-danger">Hết hạn</span>
                    }
                </p>

                <div class="d-flex gap-2 justify-content-end mt-3">
                    <form asp-action="ToggleCardStatus" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-@(Model.IsCardActive ? "secondary" : "success")">
                            <i class="bi bi-card-@(Model.IsCardActive ? "x" : "checklist") me-1"></i>
                            @(Model.IsCardActive ? "Khóa thẻ" : "Mở khóa thẻ")
                        </button>
                    </form>

                    <form asp-action="RenewCard" asp-route-id="@Model.Id" method="post" class="d-flex gap-2">
                        <select name="months" class="form-select" style="width: 120px;">
                            <option value="1">1 tháng</option>
                            <option value="3">3 tháng</option>
                            <option value="6">6 tháng</option>
                            <option value="12">12 tháng</option>
                        </select>
                        <button type="submit" class="btn btn-info">
                            <i class="bi bi-clock-history me-1"></i>Gia hạn
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
