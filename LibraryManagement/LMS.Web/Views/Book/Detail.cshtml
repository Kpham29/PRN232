@model BookVm
@{ ViewData["Title"] = "Chi tiết sách: " + Model.Title; }

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<div class="card shadow-sm">
    <div class="row g-0">
        <div class="col-md-4 text-center p-4 bg-light">
            <img src="@(Model.CoverUrl ?? "/img/no-cover.png")" class="img-fluid rounded" alt="@Model.Title" style="max-height: 400px; object-fit: cover;">
        </div>
        <div class="col-md-8">
            <div class="card-body">
                <h4 class="card-title fw-bold">@Model.Title</h4>
                <p class="text-muted mb-2"><i class="bi bi-person me-1"></i>@Model.Author</p>
                <div class="mb-3">
                    <span class="badge bg-secondary me-1">@Model.CategoryName</span>
                    <span class="badge bg-info text-dark">@Model.PublisherName</span>
                </div>
                
                <h3 class="text-primary mb-3">@Model.Price.ToString("N0") đ</h3>
                
                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item px-0"><strong>Năm xuất bản:</strong> @Model.PublishedYear</li>
                    <li class="list-group-item px-0">
                        <strong>Tình trạng:</strong> 
                        Còn <span class="fw-bold text-@(Model.CanBorrow ? "success" : "danger")">@Model.AvailableQuantity</span> / @Model.TotalQuantity bản
                    </li>
                </ul>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <h6 class="fw-bold mt-4">Mô tả nội dung</h6>
                    <p class="card-text">@Model.Description</p>
                }

                @if (Context.Session.GetString("role") == "Reader" && Model.CanBorrow)
                {
                    <div class="mt-4 pt-3 border-top">
                        <form asp-action="RequestBorrow" asp-route-id="@Model.Id" method="post" class="row g-2">
                            <div class="col-8">
                                <input name="note" class="form-control" placeholder="Ghi chú thêm (tùy chọn)..." />
                            </div>
                            <div class="col-4">
                                <button type="submit" class="btn btn-success w-100" 
                                        onclick="return confirm('Gửi yêu cầu mượn sách này?')">
                                    <i class="bi bi-send me-1"></i>Gửi yêu cầu mượn
                                </button>
                            </div>
                        </form>
                    </div>
                }
                @if (Context.Session.GetString("role") == "Admin")
                {
                    <div class="mt-4 pt-3 border-top">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2">
                            <i class="bi bi-pencil me-1"></i>Sửa sách
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
