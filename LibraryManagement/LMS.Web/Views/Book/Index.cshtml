@model BookListVm
@{ ViewData["Title"] = "Danh sách sách"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-journal-text me-1"></i> Danh sách sách</h4>
    @if (Context.Session.GetString("role") == "Admin") {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Thêm sách
        </a>
    }
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-5">
        <input name="search" value="@Model.Search" class="form-control form-control-sm"
               placeholder="Tìm theo tên sách hoặc tác giả..."/>
    </div>
    <div class="col-md-4">
        <select name="categoryId" class="form-select form-select-sm">
            <option value="">Tất cả thể loại</option>
            @foreach (var c in Model.Categories) {
                <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>
            }
        </select>
    </div>
    <div class="col-md-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-sm flex-fill">
            <i class="bi bi-search me-1"></i> Tìm
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Xóa lọc</a>
    </div>
</form>

<div class="row row-cols-2 row-cols-md-4 g-3">
@foreach (var b in Model.Books) {
    <div class="col">
        <div class="card h-100 @(!b.CanBorrow ? "opacity-75" : "")">
            <img src="@(b.CoverUrl ?? "/img/no-cover.png")" class="card-img-top"
                 style="height:160px;object-fit:cover"/>
            <div class="card-body p-2">
                <h6 class="card-title mb-1 text-truncate" title="@b.Title">@b.Title</h6>
                <p class="card-text text-muted small mb-1">@b.Author · @b.PublishedYear</p>
                <span class="badge bg-secondary">@b.CategoryName</span>
                <p class="mt-1 mb-0 small">
                    Còn: <strong class="text-@(b.CanBorrow ? "success" : "danger")">
                        @b.AvailableQuantity</strong>/@b.TotalQuantity bản
                </p>
            </div>
            <div class="card-footer p-2 d-flex gap-1 flex-wrap">
                <a asp-action="Detail" asp-route-id="@b.Id"
                   class="btn btn-sm btn-outline-primary flex-fill">Chi tiết</a>
                @if (Context.Session.GetString("role") == "Reader" && b.CanBorrow) {
                    <form asp-action="RequestBorrow" asp-route-id="@b.Id" method="post" class="flex-fill">
                        <button class="btn btn-sm btn-success w-100" onclick="return confirm('Gửi yêu cầu mượn sách này?')">
                            Mượn
                        </button>
                    </form>
                }
                @if (Context.Session.GetString("role") == "Admin") {
                    <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-warning">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <form asp-action="Delete" asp-route-id="@b.Id" method="post">
                        <button class="btn btn-sm btn-danger"
                                onclick="return confirm('Xác nhận xóa sách này?')">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
}
</div>

<div class="mt-4 d-flex align-items-center gap-2">
    @if (Model.Page > 1) {
        <a asp-action="Index" asp-route-page="@(Model.Page-1)"
           asp-route-search="@Model.Search" asp-route-categoryId="@Model.CategoryId"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-chevron-left"></i> Trang trước
        </a>
    }
    <span class="text-muted small">Trang @Model.Page</span>
    @if (Model.HasNext) {
        <a asp-action="Index" asp-route-page="@(Model.Page+1)"
           asp-route-search="@Model.Search" asp-route-categoryId="@Model.CategoryId"
           class="btn btn-outline-secondary btn-sm">
            Trang sau <i class="bi bi-chevron-right"></i>
        </a>
    }
</div>
