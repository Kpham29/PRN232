@model BookListVm
@{ ViewData["Title"] = "Danh sách sách"; }

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h2 class="display-6 fw-bold mb-0 text-gradient">
            <i class="bi bi-book-half me-2"></i>Thư viện sách
        </h2>
        <p class="text-muted small mb-0">Khám phá hàng ngàn đầu sách hấp dẫn</p>
    </div>
    <div class="col-md-6 text-md-end mt-3 mt-md-0">
        @if (Context.Session.GetString("role") == "Admin") {
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> Thêm sách mới
            </a>
        }
    </div>
</div>

<div class="glass-panel p-3 mb-5">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label small text-muted">Từ khóa tìm kiếm</label>
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-search"></i></span>
                <input name="search" value="@Model.Search" class="form-control" placeholder="Tên sách, tác giả..."/>
            </div>
        </div>
        <div class="col-md-4">
            <label class="form-label small text-muted">Thể loại</label>
            <select name="categoryId" class="form-select form-select-sm">
                <option value="">Tất cả thể loại</option>
                @foreach (var c in Model.Categories) {
                    <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm flex-fill">
                Lọc kết quả
            </button>
            <a asp-action="Index" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-arrow-counterclockwise"></i>
            </a>
        </div>
    </form>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 animate-fade-in">
@foreach (var b in Model.Books) {
    <div class="col">
        <div class="card h-100 @(!b.CanBorrow ? "opacity-50" : "") border-0 overflow-hidden shadow-lg position-relative">
            @if (!b.CanBorrow) {
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="background: rgba(15, 23, 42, 0.4); z-index: 2;">
                    <span class="badge bg-danger px-3 py-2 shadow">Hết sách</span>
                </div>
            }
            <div class="card-img-wrapper position-relative" style="height: 220px; overflow: hidden;">
                <img src="@(b.CoverUrl ?? "/img/no-cover.png")" class="card-img-top w-100 h-100" style="object-fit: cover; transition: transform 0.5s ease;"/>
                <div class="card-img-overlay d-flex align-items-start justify-content-end p-2">
                     <span class="badge rounded-pill bg-dark bg-opacity-50 backdrop-blur" style="backdrop-filter: blur(4px);">@b.PublishedYear</span>
                </div>
            </div>
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 small">@b.CategoryName</span>
                </div>
                <h6 class="card-title fw-bold mb-1 text-truncate" title="@b.Title">@b.Title</h6>
                <p class="card-text text-muted x-small mb-2"><i class="bi bi-person me-1"></i>@b.Author</p>
                
                <div class="d-flex align-items-center justify-content-between mt-auto">
                    <small class="text-muted">Còn lại: <span class="fw-bold @(b.AvailableQuantity > 0 ? "text-success" : "text-danger")">@b.AvailableQuantity</span></small>
                    <div class="text-end">
                        <span class="fs-4 fw-bold text-gradient">@b.TotalQuantity</span><span class="text-muted small"> bản</span>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top border-white border-opacity-10 p-3">
                <div class="d-flex gap-2">
                    <a asp-action="Detail" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary flex-fill fw-bold">Chi tiết</a>
                    
                    @if (Context.Session.GetString("role") == "Reader" && b.CanBorrow) {
                        <form asp-action="RequestBorrow" asp-route-id="@b.Id" method="post" class="flex-fill">
                            <button class="btn btn-sm btn-primary w-100 shadow-sm" onclick="return confirm('Gửi yêu cầu mượn sách này?')">
                                Mượn sách
                            </button>
                        </form>
                    }

                    @if (Context.Session.GetString("role") == "Admin") {
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-warning p-2">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@b.Id" method="post" class="d-inline">
                                <button class="btn btn-danger p-2" onclick="return confirm('Xác nhận xóa sách này?')">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
</div>

<div class="mt-5 d-flex justify-content-center">
    <nav>
        <ul class="pagination pagination-sm">
            @if (Model.Page > 1) {
                <li class="page-item">
                    <a class="page-link bg-dark border-secondary text-white" asp-action="Index" 
                       asp-route-page="@(Model.Page-1)" asp-route-search="@Model.Search" asp-route-categoryId="@Model.CategoryId">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
            }
            <li class="page-item disabled">
                <span class="page-link bg-primary text-white border-primary fw-bold">Trang @Model.Page</span>
            </li>
            @if (Model.HasNext) {
                <li class="page-item">
                    <a class="page-link bg-dark border-secondary text-white" asp-action="Index" 
                       asp-route-page="@(Model.Page+1)" asp-route-search="@Model.Search" asp-route-categoryId="@Model.CategoryId">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            }
        </ul>
    </nav>
</div>

<style>
    .x-small { font-size: 0.75rem; }
    .backdrop-blur { backdrop-filter: blur(4px); }
    .card-img-wrapper:hover img { transform: scale(1.1); }
    .pagination .page-link:hover { background: var(--primary-gradient) !important; color: white !important; }
</style>
