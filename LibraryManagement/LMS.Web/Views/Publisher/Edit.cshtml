@model PublisherVm
@{ ViewData["Title"] = "Chỉnh sửa nhà xuất bản"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">Chỉnh sửa nhà xuất bản</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label small fw-bold text-dark">Tên nhà xuất bản</label>
                        <input asp-for="Name" class="form-control text-dark" style="color: black !important;" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label small fw-bold text-dark">Địa chỉ</label>
                        <input asp-for="Address" class="form-control text-dark" style="color: black !important;" />
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label small fw-bold text-dark">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control text-dark" style="color: black !important;" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">Cập nhật</button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
