@model List<PublisherVm>
@{ ViewData["Title"] = "Quản lý nhà xuất bản"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-building me-1"></i> Quản lý nhà xuất bản</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Thêm nhà xuất bản
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Tên nhà xuất bản</th>
                    <th>Địa chỉ</th>
                    <th>Số điện thoại</th>
                    <th style="width: 120px;" class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Chưa có nhà xuất bản nào.</td>
                    </tr>
                }
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td class="fw-bold">@p.Name</td>
                        <td>@p.Address</td>
                        <td>@p.Phone</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-outline-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@p.Id" method="post" style="display:inline">
                                    <button type="submit" class="btn btn-outline-danger" 
                                            onclick="return confirm('Bạn chắc chắn muốn xóa nhà xuất bản này?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
